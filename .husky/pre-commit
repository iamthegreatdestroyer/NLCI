#!/bin/bash
# Pre-commit hook for NLCI
# Prevents commits with failing tests, linting issues, or type errors

set -e

echo "🔍 Running pre-commit checks..."

# Check for staged changes
if git diff --cached --quiet; then
  echo "✅ No changes to commit"
  exit 0
fi

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)

if [ -z "$STAGED_FILES" ]; then
  echo "✅ No JavaScript/TypeScript files to check"
  exit 0
fi

echo "📝 Checking files: $(echo $STAGED_FILES | wc -w) files"

# Run linting
echo "🔧 Linting..."
if ! pnpm exec lint-staged; then
  echo "❌ Linting failed. Fix issues and try again."
  exit 1
fi

# Run type checking
echo "📊 Type checking..."
if ! pnpm typecheck; then
  echo "❌ Type check failed. Fix issues and try again."
  exit 1
fi

# Run unit tests for changed files
echo "🧪 Running unit tests..."
if ! pnpm test; then
  echo "❌ Tests failed. Fix issues and try again."
  exit 1
fi

echo "✅ All pre-commit checks passed!"
exit 0
